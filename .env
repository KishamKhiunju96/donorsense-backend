# App
PORT=8080
NODE_ENV=development
APP_NAME="DonorSense API"

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/donorsense"

# Auth
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# SendGrid (Phase 2)
SENDGRID_API_KEY=SG.xxxxxxxx
SENDGRID_FROM_EMAIL=receipts@donorsense.app
SENDGRID_FROM_NAME=DonorSense

# AWS Textract (Phase 2)
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=donorsense-uploads

# Stripe (Phase 2)
STRIPE_SECRET_KEY=sk_test_xxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxx

# Frontend
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
